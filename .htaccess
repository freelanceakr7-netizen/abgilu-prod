# Enable URL rewriting
RewriteEngine On

# Set the base directory
RewriteBase /

# If an existing asset or directory is requested go to it as it is
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# If the requested resource doesn't exist, use index.html to handle client-side routing
RewriteRule ^(.+)$ /index.html [L,QSA]

# Handle specific routes that might be accessed directly
RewriteRule ^shop$ /index.html [L]
RewriteRule ^shop/(.*)$ /index.html [L]
RewriteRule ^product/(.*)$ /index.html [L]
RewriteRule ^about$ /index.html [L]
RewriteRule ^contact$ /index.html [L]
RewriteRule ^checkout$ /index.html [L]
RewriteRule ^dashboard$ /index.html [L]
RewriteRule ^admin$ /index.html [L]
RewriteRule ^orders$ /index.html [L]
RewriteRule ^downloads$ /index.html [L]
RewriteRule ^addresses$ /index.html [L]
RewriteRule ^account-details$ /index.html [L]
RewriteRule ^wishlist$ /index.html [L]
RewriteRule ^returns-policy$ /index.html [L]
RewriteRule ^terms-conditions$ /index.html [L]
RewriteRule ^privacy-policy$ /index.html [L]
RewriteRule ^login$ /index.html [L]
RewriteRule ^register$ /index.html [L]

# Handle browser caching for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/ico "access plus 1 year"
  ExpiresByType image/icon "access plus 1 year"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# Compress text files
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options nosniff
  Header always set X-Frame-Options DENY
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>